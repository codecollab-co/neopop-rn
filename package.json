{
  "name": "@codecollab.co/neopop-rn",
  "version": "2.0.0-alpha.1",
  "description": "NeoPop design system for React Native \u2014 unified iOS, Android, Web & Flutter features in one Expo-compatible package",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "homepage": "https://codecollab-co.github.io/neopop-rn/",
  "repository": {
    "type": "git",
    "url": "https://github.com/codecollab-co/neopop-rn.git"
  },
  "keywords": [
    "react-native",
    "expo",
    "neopop",
    "design-system",
    "ui-library",
    "3d",
    "animation",
    "skia",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "prepare": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "example": "npm --prefix example",
    "release": "release-it",
    "tokens": "node token-build/build.js"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=1.3.0",
    "expo-haptics": ">=14.0.0",
    "react": ">=18.3.0",
    "react-native": ">=0.76.0",
    "react-native-gesture-handler": ">=2.14.0",
    "react-native-reanimated": ">=3.6.0"
  },
  "peerDependenciesMeta": {
    "expo-haptics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^18.6.0",
    "@react-native/eslint-config": "^0.73.0",
    "@release-it/conventional-changelog": "^7.0.0",
    "@shopify/react-native-skia": "^1.3.0",
    "@storybook/addon-ondevice-actions": "^7.6.17",
    "@storybook/addon-ondevice-backgrounds": "^7.6.17",
    "@storybook/addon-ondevice-controls": "^7.6.17",
    "@storybook/addon-ondevice-notes": "^7.6.17",
    "@storybook/react-native": "^7.6.17",
    "@testing-library/react-native": "^12.4.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "commitlint": "^18.6.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "expo-haptics": "^13.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^50.0.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.2.0",
    "react": "18.2.0",
    "react-native": "0.73.4",
    "react-native-builder-bob": "^0.23.2",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^3.6.0",
    "release-it": "^16.3.0",
    "typescript": "^5.3.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esmodules": true
        }
      ],
      "module",
      "typescript"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md"
      }
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/react-native/extend-expect"
    ],
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|react-native-reanimated|react-native-gesture-handler|@shopify/react-native-skia|expo-haptics))"
    ],
    "moduleNameMapper": {
      "^neopop-rn$": "<rootDir>/src/index",
      "^@codecollab\\.co/neopop-rn$": "<rootDir>/src/index"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.types.ts",
      "!src/**/index.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 13,
        "branches": 12,
        "functions": 8,
        "lines": 13
      },
      "./src/utils/": {
        "statements": 85,
        "branches": 75,
        "functions": 80,
        "lines": 90
      },
      "./src/hooks/": {
        "statements": 90,
        "branches": 80,
        "functions": 85,
        "lines": 90
      },
      "./src/theme/NeoPopProvider.tsx": {
        "statements": 95,
        "branches": 75,
        "functions": 95,
        "lines": 95
      }
    }
  }
}
